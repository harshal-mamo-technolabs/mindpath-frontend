# Copy to .env and fill in. Vars must be prefixed with VITE_ to reach the client.

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000

# Stripe publishable key (pk_...) from Stripe Dashboard → Developers → API keys.
# The secret key (sk_...) must stay on the backend only.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
